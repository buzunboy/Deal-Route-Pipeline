{
  "name": "dealroute-pipeline",
  "version": "0.1.0",
  "private": true,
  "description": "DealRoute data pipeline — crawl, LLM extraction, evidence capture, monitoring for verified subscription-bundle deal records (Germany v1).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "dealroute": "./dist/adapters/cli/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/adapters/cli/main.ts",
    "cli": "tsx src/adapters/cli/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:live": "vitest run --config vitest.live.config.ts",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/adapters/db/migrate.ts",
    "seed:import": "tsx src/adapters/cli/main.ts seed-import",
    "dry-run-extract": "tsx src/adapters/cli/main.ts dry-run-extract",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@aws-sdk/client-s3": "^3.1073.0",
    "drizzle-orm": "^0.38.3",
    "openai": "^4.77.0",
    "pg": "^8.13.1",
    "pg-boss": "^10.1.6",
    "playwright": "^1.49.1",
    "turndown": "^7.2.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/turndown": "^5.0.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": "prettier --write",
    "*.ts": "eslint --max-warnings=0"
  }
}
