# DealRoute pipeline — environment configuration.
# Copy to `.env` and fill in. Never commit `.env`. This service has its own env,
# separate from the landing/admin repos.

# ── LLM (provider-agnostic port; selected by LLM_PROVIDER) ───────────────────
# One of: anthropic | openai | stub
#   stub = offline, no-key provider for demos / e2e dry-run / CI. With stub, set
#   STUB_LLM_RESPONSE_FILE=<path to a JSON {"deals":[...]}> to drive the output.
LLM_PROVIDER=anthropic
# Cheap/fast model for Tier 1–2 extraction; stronger model for ambiguous/agentic.
LLM_EXTRACTION_MODEL=claude-haiku-4-5-20251001
LLM_DISCOVERY_MODEL=claude-opus-4-8
LLM_MAX_OUTPUT_TOKENS=8192
LLM_TIMEOUT_MS=60000
# Supply whichever matches LLM_PROVIDER (leave the other blank).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Fetcher (Fetcher port) ───────────────────────────────────────────────────
# One of: playwright | firecrawl
FETCHER=playwright
FETCH_TIMEOUT_MS=30000
FETCH_USER_AGENT=DealRouteBot/0.1 (+https://dealroute.example/bot)
# Only needed if FETCHER=firecrawl (also reused by SEARCH_PROVIDER=firecrawl)
FIRECRAWL_API_KEY=

# ── Tier-4 broad discovery (Phase C, C-1) ────────────────────────────────────
# BrowserAgent: noop (default off-switch — Tier-4 runs nothing) | search.
AGENT=noop
# Search backend (SearchProvider port): stub (default off-switch, no network) |
# api (Brave) | firecrawl (reuses FIRECRAWL_API_KEY). Defaults to `api` when
# SEARCH_API_KEY is set, else `stub`.
SEARCH_PROVIDER=stub
# Brave Search API key (only when SEARCH_PROVIDER=api).
SEARCH_API_KEY=
SEARCH_RESULTS_PER_QUERY=10
# Estimated € cost of one search-API call (the search agent's own budget line).
SEARCH_COST_EUR=0.005
# Hard cap on search queries issued per broad-discovery run.
DISCOVERY_MAX_QUERIES=20
# Extra deny-list domains (comma/space-separated) on top of the built-in social/
# aggregator/search noise — never fetched or proposed by broad discovery.
DISCOVERY_DENY_DOMAINS=

# ── Evidence store (EvidenceStore port) ──────────────────────────────────────
# One of: local | s3
EVIDENCE_STORE=local
EVIDENCE_LOCAL_DIR=./.evidence
# Only needed if EVIDENCE_STORE=s3 (S3/R2-compatible)
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Database (Database port) ─────────────────────────────────────────────────
DATABASE_URL=postgres://dealroute:dealroute@localhost:5432/dealroute
# Connection-pool + per-statement resilience for unattended running (Pre-C-2).
# Bounds connections so a runaway run can't exhaust Postgres; statement timeout
# caps any single query so a wedged statement can't pin a connection forever.
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=10000
DB_STATEMENT_TIMEOUT_MS=30000
# Bounded retry (with backoff) for transient DB errors (connection reset,
# serialization failure, deadlock). Writes stay idempotent under retry.
DB_RETRIES=3
DB_RETRY_BASE_DELAY_MS=100
# Docker entrypoint applies migrations on start; set false if a separate job owns the schema.
RUN_MIGRATIONS=true

# ── Queue / scheduler (Queue port) ───────────────────────────────────────────
# pg-boss reuses DATABASE_URL by default; override here if separate.
QUEUE_DATABASE_URL=

# ── Crawl policy / guardrails ────────────────────────────────────────────────
DEFAULT_RECRAWL_DAYS=3
PER_DOMAIN_RATE_LIMIT_MS=2000
RESPECT_ROBOTS_TXT=true
# Per-run agentic caps (Phase B/C); enforced even though discovery is stubbed in A.
AGENT_MAX_STEPS=25
AGENT_MAX_SECONDS=300
AGENT_MAX_COST_EUR=1.00
# Aggregate €/UTC-day ceiling across ALL agentic/discovery runs (distinct from the
# per-run cap above): a discovery/ingest batch stops before starting a run once
# today's total logged cost reaches this, so a runaway day can't blow cost. 0 = off.
DAILY_BUDGET_EUR=10.00

# ── Review API ───────────────────────────────────────────────────────────────
REVIEW_API_PORT=3000
# Bearer token required on approve/reject. Leave unset ONLY if the API is bound to
# a trusted network (the production admin panel terminates real auth separately).
REVIEW_API_TOKEN=

# ── Misc ─────────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
COUNTRY=DE
CURRENCY=EUR
